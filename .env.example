# FeedLite Environment Variables Example
# Copy this file to .env and modify as needed.

# --- Basic Authentication ---
# Default admin credentials for the first run
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_strong_password_here
# Generate a random string for JWT security (e.g., openssl rand -hex 32)
JWT_SECRET=your_random_jwt_secret_here
DISABLE_AUTH=false
# Disable /docs, /redoc, and /openapi.json in production if desired.
DISABLE_DOCS=false

# --- AI: SCORER (For high-frequency article scoring) ---
# Supports: gemini, openai, anthropic
SCORER_PROVIDER=gemini
SCORER_MODEL=gemini-1.5-flash
SCORER_API_BASE=https://generativelanguage.googleapis.com
SCORER_API_KEY=your_gemini_api_key_here

# --- AI: PROFILER (For deep user profiling) ---
PROFILER_PROVIDER=gemini
PROFILER_MODEL=gemini-1.5-flash
PROFILER_API_BASE=https://generativelanguage.googleapis.com
PROFILER_API_KEY=your_gemini_api_key_here

# --- Proxy Settings (Optional) ---
# Use this to bypass IP blocks (Supports socks5:// or http://)
# Inside Docker, use 172.17.0.1 to access host proxy
# AI_SPECIFIC_PROXY=socks5://172.17.0.1:40000
AI_SPECIFIC_PROXY=

# --- RAG API (For OpenClaw or other internal AI callers) ---
RAG_API_KEY=your_private_rag_api_key_here

# --- Scheduling (Future/Optional) ---
# Frequency of RSS fetching in hours (Default: 12)
RSS_FETCH_INTERVAL=12
